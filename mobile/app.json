{
  "expo": {
    "name": "myapp",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "newArchEnabled": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      },
      "newArchEnabled": true
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "newArchEnabled": true,
      "tsconfigPaths": true
    },
    "_internal": {
      "isDebug": false,
      "fastRefresh": false,
      "newArchEnabled": true
    }
  }
}
