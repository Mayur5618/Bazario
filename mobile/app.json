{
  "expo": {
    "name": "myapp",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "your-scheme",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "newArchEnabled": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "newArchEnabled": true,
      "navigationBar": {
        "visible": "immersive"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "newArchEnabled": true,
      "tsconfigPaths": true
    },
    "_internal": {
      "isDebug": false,
      "fastRefresh": false,
      "newArchEnabled": true
    }
  }
}
